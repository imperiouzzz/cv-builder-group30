# ── Database ─────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/cvbuilder_dev"

# ── Auth ──────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-long-random-string-in-production"
